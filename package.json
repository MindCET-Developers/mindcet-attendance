{
  "name": "mindcet-attendance",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev:web": "pnpm --filter @att/web dev",
    "build:web": "pnpm --filter @att/web build",
    "dev:mobile": "pnpm --filter @att/mobile dev",
    "build:mobile": "pnpm --filter @att/mobile build"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "5.7.2"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.15",
      "typescript": "5.7.2"
    },
    "packageExtensions": {
      "next@*": {
        "peerDependencies": {
          "@types/react": "*"
        },
        "peerDependenciesMeta": {
          "@types/react": {
            "optional": true
          }
        }
      }
    }
  }
}
