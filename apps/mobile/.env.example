# --- Supabase ---
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Base URL of the deployed web app — used for server-side actions like email export.
# In development, run the web app on port 3000 and set this to http://localhost:3000.
EXPO_PUBLIC_WEB_BASE_URL=https://your-web-app.vercel.app

# --- Google OAuth redirect (deep link back into the app after Supabase auth) ---
# Configured as an additional redirect URL in Supabase Auth settings:
# mindcet-attendance://auth/callback
