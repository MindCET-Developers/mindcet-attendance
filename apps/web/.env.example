# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only (never expose to the client):
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Google Sheets export (P5) ---
# Scopes requested at sign-in: drive.file + spreadsheets (see login page).
# These must be the SAME Client ID/Secret entered in Supabase →
# Authentication → Providers → Google. We use them server-side to exchange
# the stored refresh token for a short-lived access token before each export.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email export (POST /api/export/email) ---
# Sign up at resend.com → create API key → verify a sender domain.
# During local dev you can use onboarding@resend.dev as RESEND_FROM_EMAIL
# (only works when sending to the address that owns the Resend account).
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
