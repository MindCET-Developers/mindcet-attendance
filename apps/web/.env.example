# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only (never expose to the client):
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Google (for Google Sheets export; configured in Supabase Auth provider) ---
# Scopes requested at sign-in: drive.file + spreadsheets
# No extra keys needed here when using the Supabase Google provider token,
# but if you call the Sheets API with a service account add its JSON below:
# GOOGLE_SERVICE_ACCOUNT_JSON=
